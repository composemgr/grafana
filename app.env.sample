# Grafana environment configuration
# Copy to app.env and customize before starting

# Timezone
TZ=America/New_York

# Public URL
BASE_HOST_NAME=grafana.example.com

# Admin credentials
APP_ADMIN_USER=admin
APP_ADMIN_PASS=changeme_admin_password

# Secret key (used for signing tokens, min 32 chars)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Comma-separated list of plugins to install (optional)
GF_INSTALL_PLUGINS=

# Run as this UID:GID (must own the data volume)
SERVICE_USER=1000
SERVICE_GROUP=1000

# Email / SMTP
EMAIL_SERVER_HOST=172.17.0.1
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASS=
EMAIL_SERVER_MAIL_FROM=grafana@example.com
